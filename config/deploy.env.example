# These are the GitHub Actions secret names the Release workflow reads. Set them
# under the repo's Settings → Secrets and variables → Actions (see docs/RELEASE.md);
# this file is a reference only. Every one is optional — any left unset just skips
# that bit of signing, so the build still produces installable (unsigned) bundles.

# Tauri updater signing key — only needed if the app has an auto-updater
# (see `tauri signer generate`). NOT OS code signing.
TAURI_SIGNING_PRIVATE_KEY=changeme
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=changeme

# macOS code signing: a "Developer ID Application" certificate exported as .p12,
# base64-encoded (`base64 -i cert.p12`).
APPLE_CERTIFICATE=base64-of-developer-id-application.p12
APPLE_CERTIFICATE_PASSWORD=changeme
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAMID)

# macOS notarization (Apple).
APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=changeme
APPLE_TEAM_ID=XXXXXXXXXX

# Windows Authenticode: a code-signing certificate exported as .pfx,
# base64-encoded (`base64 -i cert.pfx`). The workflow imports it and signs.
WINDOWS_CERTIFICATE=base64-of-cert.pfx
WINDOWS_CERTIFICATE_PASSWORD=changeme
