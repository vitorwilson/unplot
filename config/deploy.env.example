# Copy to config/deploy.env (gitignored) and fill in real values.
# Never commit the filled-in file, and never put real secrets here.

# Tauri updater / bundle signing key (see `tauri signer generate`)
TAURI_SIGNING_PRIVATE_KEY=changeme
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=changeme

# macOS notarization (Apple)
APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=changeme
APPLE_TEAM_ID=XXXXXXXXXX

# Windows code-signing certificate (base64-encoded .pfx)
WINDOWS_CERTIFICATE=changeme
WINDOWS_CERTIFICATE_PASSWORD=changeme

# GitHub release upload
GITHUB_TOKEN=changeme
