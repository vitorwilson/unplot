{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://github.com/vitorwilson/unplot" },
        { "url": "https://github.com/vitorwilson/unplot/issues" }
      ]
    }
  ]
}
